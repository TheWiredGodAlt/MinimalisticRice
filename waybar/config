{
    "height": 40,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "position": "top",
    "layer": "bot",
    "modules-left": ["custom/gentoo", "hyprland/workspaces", "hyprland/window"],
    "modules-center": ["memory","clock","cpu"],
    "modules-right": ["custom/applauncher", "tray","hyprland/language","pulseaudio","battery","network"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "active": "󱓻",
            "default": "󱓼"
        }
   },

    "hyprland/window": {
        "rewrite": {
            "":"Hypr"
        }
    },

    "backlight": { "format": "{icon} {percent}%", "format-icons": ["󰃞", "󰃟", "󰃠"],
        "reverse-scrolling": true
    },

    "custom/gentoo": {
        "format": "󰣇  ArchLinux",
        "tooltip-format": "Am I autistic? Yes!"
    },

    "network": {
        "format-ethernet": "󰈀 ",
        "format-wifi": "󰖩 ",
        "tooltip-format": "{ifname} via {gwaddr}",
        "tooltip-format-wifi": "Connnected to {essid} through {ifname} ({signalStrength}%)"
    },

  "cpu": {
        "format": "   {usage}%",
        "tooltip": true,
        "interval": 5,
        "max-length": 15
    },
    
    "memory": {
        "format": "󰪞  {percentage}%",
        "tooltip": true,
        "interval": 5,
        "max-length": 20,
        "states": {
            "warning": 70,
            "critical": 90
        }
    },
    "hyprland/language": {
        "format": "󰣩 {}"
    },

    "clock": {
        "interval": 5,
        "format": "{:%a %m-%d %H:%M}"
    },

    "pulseaudio": {
        "format-icons": ["󰖀", "󰕾"],
        "format": "{icon}  {volume}",
        "format-muted": "󰖁",
        "tooltip":true,
        "tooltip-format":"{volume}%",
        "reverse-scrolling": true
    },

    "battery": {
        "interval": 10,
        "format-charging": "󰂄",
        "format": "{icon}",
        "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁿", "󰂀", "󰂂", "󰁹"],
        "tooltip-format":"{capacity}%"
    },
    "custom/applauncher": {
        "format": "",
        "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun --location 3",
        "tooltip": false
    },

    "tray": {
        "spacing": 10,
        "tooltip": false
  }
}

