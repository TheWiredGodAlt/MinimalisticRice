{
    "height": 40,
    "margin-top": 0,
    "margin-left": 1,
    "margin-right": 1,
    "position": "top",
    "layer": "bot",
    "modules-left": ["custom/gentoo", "sway/workspaces", "sway/window"],
    "modules-center": ["clock","custom/applauncher"],
    "modules-right": ["backlight", "pulseaudio", "battery", "network", "sway/language", "tray"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "focused": "󱓻",
            "default": "󱓼"
        }
   },

    "sway/window": {
        "rewrite": {
            "": "sway"
        }
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"],
        "reverse-scrolling": true
    },

    "custom/gentoo": {
        "format": "󰣇  ArchLinux",
        "tooltip-format": "Am I autistic? Yes!"
    },

    "network": {
        "format-ethernet": "󰈀",
        "format-wifi": "󰖩 {essid}",
        "tooltip-format": "{ifname} via {gwaddr}",
        "tooltip-format-wifi": "Connnected through {ifname} ({signalStrength}%)"
    },

    "sway/language": {
        "format": "󰣩 {}"
    },

    "clock": {
        "interval": 5,
        "format": "󰥔 {:%H:%M 󰃭 %a %Y-%m-%d}"
    },

    "pulseaudio": {
        "format-icons": ["󰖀", "󰕾"],
        "format": "{icon} {volume}%",
        "format-muted": "󰖁",
        "reverse-scrolling": true
    },

    "battery": {
        "interval": 10,
        "format-charging": "󰂄 {capacity}%",
        "format": "{icon} {capacity}%",
        "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁿", "󰂀", "󰂂", "󰁹"]
    },
    "custom/applauncher": {
        "format": "〇",
        "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun --location=top -y 15",
        "tooltip": false
    },

    "tray": {
        "spacing": 10,
        "tooltip": false
  }
}

